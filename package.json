{
  "name": "@alpha-aml/kyt-sdk",
  "version": "1.0.0",
  "description": "Alpha AML Know-Your-Transaction SDK for B2B integrations — tracks stablecoin inflows, performs KYT checks, and auto-forwards compliant funds.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "lint": "tsc --noEmit",
    "example:basic": "tsx examples/basic.ts",
    "example:aws": "tsx examples/aws-kms.ts",
    "example:vault": "tsx examples/vault.ts"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.650.0",
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "@scure/base": "^1.1.9",
    "@scure/bip32": "^1.4.0",
    "@scure/bip39": "^1.3.0",
    "axios": "^1.7.0",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.0",
    "node-vault": "^0.10.0",
    "tronweb": "^5.3.2",
    "uuid": "^10.0.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alpha-AML/kyt-sdk"
  }
}
