# ============================================================
# Alpha AML KYT SDK — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# For production, prefer AWS KMS or HashiCorp Vault providers.
# ============================================================

# ----------------------------------------------------------
# Secrets (required)
# ----------------------------------------------------------

# Master seed for HD wallet derivation (hex-encoded, 32 bytes / 64 hex chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Store in a KMS for production — this controls ALL derived wallets.
KYT_MASTER_SEED=your_64_char_hex_seed_here

# Private key of the gas reserve wallet (hex, no 0x prefix).
# This wallet must hold native tokens on each chain you use (ETH, BNB, TRX, etc.)
# to fund tracking wallets for gas when forwarding stablecoins.
KYT_GAS_RESERVE_KEY=your_64_char_hex_private_key

# Alpha AML API key (issued via alpha-aml.com dashboard).
KYT_ALPHA_AML_API_KEY=your_alpha_aml_api_key

# ----------------------------------------------------------
# Webhook (optional)
# ----------------------------------------------------------

# URL to receive SDK event notifications (transaction detected, KYT result, etc.)
# KYT_WEBHOOK_URL=https://your-server.example.com/webhooks/kyt

# HMAC-SHA256 secret for verifying webhook payloads.
# KYT_WEBHOOK_SECRET=your_webhook_hmac_secret

# Outbound webhook: scripts POST payment events here (gas_wallet_ready, deposit_detected, etc.)
# Use https://webhook.site for testing — no server needed.
# PAYMENT_WEBHOOK_URL=https://webhook.site/your-unique-id

# ----------------------------------------------------------
# AWS KMS provider (if using AwsKmsSecretsProvider)
# ----------------------------------------------------------

# AWS_REGION=us-east-1
# AWS_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/your-key-id
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# ----------------------------------------------------------
# HashiCorp Vault provider (if using VaultSecretsProvider)
# ----------------------------------------------------------

# VAULT_ADDR=https://vault.example.com:8200
# VAULT_TOKEN=hvs.your_vault_token
# VAULT_PATH=secret/data/kyt-sdk
# VAULT_NAMESPACE=            # optional, for Vault Enterprise

# ----------------------------------------------------------
# Chain RPC URLs
# ----------------------------------------------------------

# Mainnets
# ETH_RPC_URL=https://mainnet.infura.io/v3/your-key
# ARB_RPC_URL=https://arb1.arbitrum.io/rpc
# BASE_RPC_URL=https://mainnet.base.org
# BSC_RPC_URL=https://bsc-dataseed.binance.org

# Ethereum Sepolia testnet
# ETH_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your-key
# USDC on Ethereum Sepolia: 0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238 (Circle faucet: https://faucet.circle.com)
# USDT on Ethereum Sepolia: 0x7169D38820dfd117C3FA1f22a697dBA58d90BA06 (CoinsPaid code: USDTE — supports deposit AND withdrawal in sandbox)

# Arbitrum Sepolia testnet
# ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
# USDC on Arbitrum Sepolia: 0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d (Circle faucet: https://faucet.circle.com)

# ----------------------------------------------------------
# CoinsPaid integration (create_and_tracking_buffer_wallet.ts)
# ----------------------------------------------------------

# CoinsPaid API URL (from CoinsPaid dashboard)
# Sandbox: https://app.sandbox.cryptoprocessing.com/api/v2
# Production: https://app.ca.cryptoprocessing.com/api/v2
COINSPAID_API_URL=https://app.sandbox.cryptoprocessing.com/api/v2
# COINSPAID_API_KEY and COINSPAID_API_SECRET are stored in Vault (fields: COINSPAID_API_KEY, COINSPAID_API_SECRET)

# Port for the local CoinsPaid webhook receiver.
# For local testing, expose with: npx ngrok http 3000
# Then set the ngrok URL in CoinsPaid dashboard → Callbacks.
COINSPAID_WEBHOOK_PORT=3000

# CoinsPaid KYC / compliance fields (required by CoinsPaid for every address/withdrawal request)
# sender_type is always "legal" for B2B use — provide your company info below.
COINSPAID_COMPANY_NAME=YourCompanyName
COINSPAID_COMPANY_COUNTRY=EST    # ISO alpha-3 country code, e.g. USA, EST, GBR
# Note: customer ID (end_user_reference) is passed per-payment via --customer-id CLI arg,
# not as an env variable — it must be unique per customer, not a global setting.
